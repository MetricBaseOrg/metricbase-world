{
  "name": "@metricbase/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "dev:env": "tsx --env-file=.env src/index.ts",
    "build": "tsc && node --input-type=module -e \"import { cpSync } from 'node:fs'; cpSync('src/db/schema.sql','dist/db/schema.sql');\"",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:init": "tsx --env-file=.env scripts/init-db.ts"
  },
  "dependencies": {
    "@colyseus/core": "^0.16.0",
    "@colyseus/schema": "^3.0.0",
    "@colyseus/ws-transport": "^0.16.0",
    "@metricbase/shared": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/pg": "^8.11.10",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}