# Client (set in Vercel project settings)
VITE_SERVER_URL=wss://your-game-server.up.railway.app
VITE_SERVER_HTTP_URL=https://your-game-server.up.railway.app

# Server (set on Railway — NOT Vercel)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?uselibpqcompat=true&sslmode=require
PORT=2567

# Solana token gate
TOKEN_MINT=DN2PNrZ8Jn65ioJw4QBwXv49j5JiBBL3wPLUDZcrpump
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-helius-api-key
AUTH_SECRET=replace-with-long-random-secret
# Tokens required to ENTER the world. 0 = free to play (the live default since
# v0.172.0) — a signature-verified wallet is still required, it just isn't
# screened on balance. Set a positive number to re-introduce a holding gate.
MIN_TOKEN_UI_AMOUNT=0
TOKEN_TREASURY_WALLET=your-treasury-solana-wallet-address
TOKEN_DECIMALS=6

# Casino (Lodge Blackjack) — the house hot wallet that signs withdrawal payouts.
# Secret key for the TOKEN_TREASURY_WALLET address, as bs58 or a JSON byte array.
# Deposits work without it; cash-out stays disabled until this is set + funded.
HOUSE_WALLET_SECRET=

# LOCAL DEV ONLY — and it is NOT the free-to-play switch (use
# MIN_TOKEN_UI_AMOUNT=0 for that). This bypasses wallet AUTHENTICATION
# entirely: /auth/verify hands out a session for any wallet string without
# checking the signature or the ban list. It is therefore honoured only when
# NODE_ENV is explicitly "development" or "test", and ignored (with an error
# logged) anywhere else, including when NODE_ENV is unset — as it is on Railway.
TOKEN_GATE_DISABLED=true

# Telegram Mini App (see docs/telegram-mini-app.md).
# Server: the BotFather token. Required for Telegram login — without it the
# initData HMAC can't be verified, so /api/auth/telegram refuses (503) rather
# than trusting a forgeable payload, and the client hides the button.
TELEGRAM_BOT_TOKEN=

# Client (Vercel, build-time): the bot username hosting the Mini App, e.g.
# MetricBaseWorldBot. Until it is set, every Telegram CTA stays hidden.
VITE_TELEGRAM_BOT=

# Local test servers only — skip the invite-code gate.
INVITATION_SYSTEM_DISABLED=true